#!/usr/bin/make -f

%:
	dh $@ --buildsystem=meson

override_dh_auto_configure:
	dh_auto_configure -- -Dmanpage=true

override_dh_auto_install:
	dh_auto_install --destdir=debian/tmp

	# Stage packaging payloads that are still assembled outside Meson.
	install -d debian/tmp/usr/share/vaulthalla-web

	@if [ ! -d web/.next/standalone ]; then \
		echo "Missing web/.next/standalone. Run web production build before Debian packaging."; \
		exit 1; \
	fi
	@if [ ! -d web/.next/static ]; then \
		echo "Missing web/.next/static. Run web production build before Debian packaging."; \
		exit 1; \
	fi
	cp -a web/.next/standalone/. debian/tmp/usr/share/vaulthalla-web/
	install -d debian/tmp/usr/share/vaulthalla-web/.next
	cp -a web/.next/static debian/tmp/usr/share/vaulthalla-web/.next/
	if [ -d web/public ]; then cp -a web/public debian/tmp/usr/share/vaulthalla-web/; fi
